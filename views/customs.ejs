<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">

    <script>
        (function () {
            const savedTheme = localStorage.getItem('theme') || 'system';
            if (savedTheme === 'dark' || (savedTheme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else {
                document.documentElement.removeAttribute('data-theme');
            }
        })();
    </script>
</head>

<body>

    <div class="bg-pattern-overlay"></div>

    <header>
        <div class="site-title">
            <a href="/"><img src="/icon.png" alt="Awing Logo" class="header-logo"></a>
            <a href="/"><span>exlore<span class="title-name">AWING</span></span></a>
        </div>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/origin">Origins</a></li>
                <li><a href="/meals">Meals</a></li>
                <li><a href="/customs" class="active">Customs</a></li>
            </ul>

            <div class="theme-switch-container">
                <select id="themeSelector" class="theme-select">
                    <option value="light">Light Theme</option>
                    <option value="dark">Dark Theme</option>
                    <option value="system">Match System</option>
                </select>
            </div>
        </nav>
    </header>

    <script>
        const themeSelector = document.getElementById('themeSelector');

        // Initializing the value of the select according to local storage
        const currentTheme = localStorage.getItem('theme') || 'system';
        themeSelector.value = currentTheme;

        function applyTheme(theme) {
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else if (theme === 'light') {
                document.documentElement.removeAttribute('data-theme');
            } else {
                // match device mode
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                } else {
                    document.documentElement.removeAttribute('data-theme');
                }
            }
        }

        // Get the manual switching
        themeSelector.addEventListener('change', (e) => {
            const selected = e.target.value;
            localStorage.setItem('theme', selected);
            applyTheme(selected);
        });

        // Get the automatic chages of the device if it's in match device mode
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            if (localStorage.getItem('theme') === 'system' || !localStorage.getItem('theme')) {
                applyTheme('system');
            }
        });
    </script>

    <section class="hero">
        <h1><span class="txt-gold">Sacred</span> Customs</h1>
        <p>Authentic records and sacred cultural aspects retrieved from our historical heritage.</p>
    </section>

    <main class="container">
        <% traditions.forEach(item=> { %>
            <div class="card">
                <div class="card-color-block"></div>
                <div class="card-content">
                    <span class="tag">
                        <%= item.category %>
                    </span>
                    <h2>
                        <%= item.title %>
                    </h2>
                    <p>
                        <%= item.description %>
                    </p>
                </div>
            </div>
            <% }) %>
    </main>

    <footer>
        <p>&copy 2026 Awing Cultural Project &bull; Academic Programming Assignment</p>
    </footer>

</body>
</html>