<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
    <link rel="shortcut icon" href="icon.png" type="image.png"/>
</head>
<body>
    <header>
        <div class="site-title">AWING HERITAGE</div>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/origin">Origins</a></li>
                <li><a href="/meals">Meals</a></li>
                <li><a href="/customs">Customs</a></li>
            </ul>
        </nav>
    </header>

    <section class="hero">
        <h1><%= headerTitle %></h1>
        <p>Discover the secrets of the North-West Region's most vibrant culture.</p>
    </section>

    <div class="container">
        <% traditions.forEach(item => { %>
            <div class="carte">
                <div class="card-content">
                    <span class="tag"><%= item.category %></span>
                    <h2><%= item.title %></h2>
                    <p><%= item.description %></p>
                </div>
            </div>
        <% }) %>
    </div>

    <footer>
        &copy; 2026 Explore Awing Project - Web Programming Assignment
    </footer>
</body>
</html>